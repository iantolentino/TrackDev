DATABASE_URL="mysql://username:password@localhost:3306/trackdev"
JWT_SECRET="your-super-secret-jwt-key"

# SMTP via Office365/Outlook (smtp.office365.com:587). If the mailbox has MFA
# enabled, EMAIL_PASS must be an app password, not the regular login password.
# If SMTP AUTH is disabled tenant-wide, an admin must enable it for this mailbox.
EMAIL_USER="your-name@yourcompany.com"
EMAIL_PASS="app-password"
PORT=5000
CLIENT_URL="http://localhost:5174"

# Used only by `npm run db:seed` to create/update the initial ADMIN account
ADMIN_EMAIL="admin@trackdev.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"
